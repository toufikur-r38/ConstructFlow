DEFAULT_ADMIN_PASSWORD="change-this-demo-password"
FLASK_APP=main.py
FLASK_DEBUG=1
FLASK_ENV=development
SECRET_KEY=change-this-secret-key
WTF_CSRF_TIME_LIMIT=3600

# Use this for PostgreSQL. Replace user, password, host, port, and database name.
DATABASE_URL=
# DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/constructflow

# Required outside development. Redis can serve both cache and rate-limit storage.
REDIS_URL=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# Manual PostgreSQL backup settings
BACKUP_DIR=backups/database
BACKUP_RETENTION_DAYS=30
BACKUP_KEEP_MONTHLY=12
# Optional on Windows if PostgreSQL client tools are not on PATH.
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\16\bin\pg_dump.exe
